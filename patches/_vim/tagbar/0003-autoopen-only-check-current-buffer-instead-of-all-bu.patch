From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yousong Zhou <yous.zhouys@alibaba-inc.com>
Date: Fri, 17 Jul 2026 05:19:22 +0000
Subject: [PATCH 3/3] autoopen: only check current buffer instead of all
 buffers

Previously tagbar#autoopen() looped through all listed buffers (bufnr
1..$) and would open tagbar if ANY buffer had a valid filetype.  This
caused tagbar to open when switching to an unsupported filetype tab
(e.g. tsv) while a supported buffer (e.g. sh) existed elsewhere.

Now only check the current buffer, so tagbar opens only when the active
buffer has a supported ctags filetype.
---
 autoload/tagbar.vim | 22 ++++++++++------------
 1 file changed, 10 insertions(+), 12 deletions(-)

diff --git a/autoload/tagbar.vim b/autoload/tagbar.vim
index 94d9fae..9c6a15f 100644
--- a/autoload/tagbar.vim
+++ b/autoload/tagbar.vim
@@ -3875,25 +3875,23 @@ function! tagbar#getusertypes() abort
 endfunction
 
 " tagbar#autoopen() {{{2
-" Automatically open Tagbar if one of the open buffers contains a supported
-" file
+" Automatically open Tagbar if the current buffer contains a supported file
 function! tagbar#autoopen(...) abort
     call tagbar#debug#log('tagbar#autoopen called [' . bufname('%') . ']')
     let always = a:0 > 0 ? a:1 : 1
 
     call s:Init(0)
 
-    for bufnr in range(1, bufnr('$'))
-        if buflisted(bufnr) && (always || bufwinnr(bufnr) != -1)
-            let ftype = s:DetectFiletype(bufnr)
-            if s:IsValidFile(bufname(bufnr), ftype)
-                call s:OpenWindow('')
-                call tagbar#debug#log('tagbar#autoopen finished after finding valid ' .
-                           \ 'file [' . bufname(bufnr) . ']')
-                return
-            endif
+    let bufnr = bufnr('%')
+    if buflisted(bufnr) && (always || bufwinnr(bufnr) != -1)
+        let ftype = s:DetectFiletype(bufnr)
+        if s:IsValidFile(bufname(bufnr), ftype)
+            call s:OpenWindow('')
+            call tagbar#debug#log('tagbar#autoopen finished after finding valid ' .
+                       \ 'file [' . bufname(bufnr) . ']')
+            return
         endif
-    endfor
+    endif
 
     call tagbar#debug#log('tagbar#autoopen finished without finding valid file')
 endfunction
